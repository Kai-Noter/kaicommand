# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# NextAuth – required for session and password encryption
NEXTAUTH_SECRET="generate-a-long-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Optional: require login for all API routes (default: demo user when not logged in)
# REQUIRE_AUTH=true

# Optional: credentials login (email + this password). If set, user can sign in with any email and this password.
# AUTH_DEMO_PASSWORD="your-secret-demo-password"
